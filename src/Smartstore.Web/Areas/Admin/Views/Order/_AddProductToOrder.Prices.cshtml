@model AddOrderProductModel

@{
    var primaryCurrencyCode = CommonServices.CurrencyService.PrimaryCurrency.CurrencyCode;
    var inclTax = T("Admin.Orders.Fields.Edit.InclTax", primaryCurrencyCode);
    var exclTax = T("Admin.Orders.Fields.Edit.ExclTax", primaryCurrencyCode);

    // TODO: (mg) Very awkward to enter gross, net, and tax amounts without automatic calculation. TBD with MC.
    // TODO: (mg) Add a TaxCalculatorTagHelper (see "taxcalc-pair" below).
}

<div class="adminContent">
    <div class="adminRow">
        <div class="adminTitle">
            <smart-label asp-for="Quantity" />
        </div>
        <div class="adminData">
            <editor asp-for="Quantity" data-tax-field="quantity" />
        </div>
    </div>
    <div class="adminRow">
        <div class="adminTitle">
            <smart-label asp-for="TaxRate" />
        </div>
        <div class="adminData">
            <editor asp-for="TaxRate" sm-postfix="%" data-tax-field="rate" />
        </div>
    </div>
    <div class="adminRow">
        <div class="adminTitle">
            <smart-label asp-for="UnitPriceInclTax" />
        </div>
        <div class="adminData" data-tax-pair="unitprice" data-tax-active>
            <div class="row g-1 flex-nowrap">
                <div class="col">
                    <editor asp-for="UnitPriceInclTax" sm-postfix="@inclTax" data-tax-field="gross" />
                </div>
                <div class="col-auto align-content-center">
                    <button type="button" 
                            class="btn btn-sm border-0 shadow-none bg-transparent text-reset p-1 btn-tax-lock"
                            title="@T("Admin.Common.TaxCalculator.Disable")">
                        <i class="fa fa-lock"></i>
                    </button>
                </div>
                <div class="col">
                    <editor asp-for="UnitPriceExclTax" sm-postfix="@exclTax" data-tax-field="net" />
                </div>
            </div>
        </div>
    </div>
    <div class="adminRow">
        <div class="adminTitle">
            <smart-label asp-for="PriceInclTax" />
        </div>
        <div class="adminData" data-tax-pair="total" data-tax-active>
            <div class="row g-1 flex-nowrap">
                <div class="col">
                    <editor asp-for="PriceInclTax" sm-postfix="@inclTax" data-tax-field="gross" />
                </div>
                <div class="col-auto align-content-center">
                    <button type="button"
                            class="btn btn-sm border-0 shadow-none bg-transparent text-reset p-1 btn-tax-lock"
                            title="@T("Admin.Common.TaxCalculator.Disable")">
                        <i class="fa fa-lock"></i>
                    </button>
                </div>
                <div class="col">
                    <editor asp-for="PriceExclTax" sm-postfix="@exclTax" data-tax-field="net" />
                </div>
            </div>
        </div>
    </div>
</div>
