@using Smartstore.Core.Checkout.Tax

@model OrderModel

@inject TaxSettings TaxSettings

@{
    var primaryCurrencyCode = (string)ViewBag.PrimaryStoreCurrencyCode;
    var inclTax = T("Admin.Orders.Fields.Edit.InclTax", primaryCurrencyCode);
    var exclTax = T("Admin.Orders.Fields.Edit.ExclTax", primaryCurrencyCode);

    var taxPairMode = TaxPairMode.Edit | (Model.TaxRatesList.Count > 1 ? 0 : TaxPairMode.Calculate);
    var taxRate = Model.TaxRatesList.Count > 1 ? "0" : Model.TaxRatesList[0].Rate;
}

<script src="~/admin/js/admin.taxcalculator.js" sm-target-zone="scripts" sm-key="tax-calculator"></script>

<div id="order-total-controls" class="card">
    <div class="adminContent card-body px-4 py-3">
        <div class="adminRow">
            <div class="adminTitle">
                <smart-label asp-for="OrderSubtotalInclTax" />
            </div>
            <div class="adminData">
                <tax-pair asp-for-gross="OrderSubtotalInclTax" asp-for-net="OrderSubtotalExclTax" kind="TaxPairKind.Subtotal" mode="@taxPairMode" />
            </div>
        </div>
        <div class="adminRow">
            <div class="adminTitle">
                <smart-label asp-for="OrderSubTotalDiscountInclTax" />
            </div>
            <div class="adminData">
                <tax-pair asp-for-gross="OrderSubTotalDiscountInclTax" asp-for-net="OrderSubTotalDiscountExclTax" kind="TaxPairKind.Discount" mode="@taxPairMode" />
            </div>
        </div>
        <div class="adminRow">
            <div class="adminTitle">
                <smart-label asp-for="OrderShippingInclTax" />
            </div>
            <div class="adminData">
                <tax-pair asp-for-gross="OrderShippingInclTax" asp-for-net="OrderShippingExclTax" kind="TaxPairKind.Shipping" mode="@taxPairMode" />
            </div>
        </div>
        <div class="adminRow">
            <div class="adminTitle">
                <smart-label asp-for="PaymentMethodAdditionalFeeInclTax" />
            </div>
            <div class="adminData">
                <tax-pair asp-for-gross="PaymentMethodAdditionalFeeInclTax" asp-for-net="PaymentMethodAdditionalFeeExclTax" kind="TaxPairKind.PaymentFee" mode="@taxPairMode" />
            </div>
        </div>
        <div class="adminRow">
            <div class="adminTitle">
                <smart-label asp-for="TaxRates" />
            </div>
            <div class="adminData">
                <editor asp-for="TaxRates" data-tax-field="taxrates" />
            </div>
        </div>
        <div class="adminRow">
            <div class="adminTitle">
                <smart-label asp-for="OrderTax" />
            </div>
            <div class="adminData">
                <editor asp-for="OrderTax" sm-postfix="@primaryCurrencyCode" data-tax-field="taxamount" />
            </div>
        </div>
        <div class="adminRow">
            <div class="adminTitle">
                <smart-label asp-for="OrderDiscount" />
            </div>
            <div class="adminData">
                <editor asp-for="OrderDiscount" sm-postfix="@primaryCurrencyCode" data-tax-field="orderdiscount" />
            </div>
        </div>
        <div class="adminRow">
            <div class="adminTitle">
                <smart-label asp-for="CreditBalance" />
            </div>
            <div class="adminData">
                <editor asp-for="CreditBalance" sm-postfix="@primaryCurrencyCode" data-tax-field="creditbalance" />
            </div>
        </div>
        <div class="adminRow">
            <div class="adminTitle">
                <smart-label asp-for="OrderTotalRounding" />
            </div>
            <div class="adminData">
                <editor asp-for="OrderTotalRounding" sm-postfix="@primaryCurrencyCode" data-tax-field="rounding" />
            </div>
        </div>
        <div class="adminRow">
            <div class="adminTitle">
                <smart-label asp-for="OrderTotal" />
            </div>
            <div class="adminData">
                <editor asp-for="OrderTotal" sm-postfix="@primaryCurrencyCode" data-tax-field="total" />
            </div>
        </div>
    </div>
</div>

<div class="adminContent mt-2">
    <div class="adminRow">
        <div class="w-auto">
            <button type="submit" id="btnEditOrderTotals" name="btnEditOrderTotals" class="btn btn-secondary">
                <i class="far fa-edit"></i>
                <span>@T("Admin.Orders.Fields.EditOrderTotals")</span>
            </button>
            <button type="submit" id="btnSaveOrderTotals" name="btnSaveOrderTotals" value="@T(" Admin.Orders.Fields.SaveOrderTotals")" class="btn btn-warning confirm">
                <i class="fa fa-check"></i>
                <span>@T("Admin.Orders.Fields.SaveOrderTotals")</span>
            </button>
            <button type="submit" id="btnCancelOrderTotals" name="btnCancelOrderTotals" class="btn btn-secondary">
                <span>@T("Admin.Common.Cancel")</span>
            </button>

            <zone name="admin_order_total_edit_buttons_after" />
        </div>
    </div>
    <div class="adminRow">
        <div class="adminSeparator"><hr /></div>
    </div>
</div>

<script sm-target-zone="scripts" sm-minify="true" data-origin="order-edit-totals">
    $(function () {
        toggleOrderTotals(false);

        $('#btnEditOrderTotals, #btnCancelOrderTotals').on('click', function (e) {
            e.preventDefault();
            toggleOrderTotals($(this).attr('id') === 'btnEditOrderTotals');
            return false;
        });

		const taxCalc = new Smartstore.Admin.TaxCalculator({
            rootSelector: '#order-total-controls',
			pricesIncludeTax: @(TaxSettings.PricesIncludeTax.ToStringLower()),
            taxRate: @taxRate,
			res: {
				@foreach (var key in new[]
				{
					"Admin.Common.TaxCalculator.Enable",
					"Admin.Common.TaxCalculator.Disable"
				})
				{
					<text>"@(Html.Raw(key))": @(T(key).JsValue),</text>
				}
			}
		});


        function toggleOrderTotals(editmode) {
            if (editmode) {
                $('#order-total-controls').show();
                $('#btnEditOrderTotals').hide();
                $('#btnSaveOrderTotals').show();
                $('#btnCancelOrderTotals').show();
            }
            else {
                $('#order-total-controls').hide();
                $('#btnEditOrderTotals').show();
                $('#btnSaveOrderTotals').hide();
                $('#btnCancelOrderTotals').hide();
            }
        }
    });
</script>