@using Smartstore.Core.Catalog.Products
@using Smartstore.Core.Checkout.Tax

@model AddOrderProductModel

@inject TaxSettings TaxSettings

@{
    ViewBag.Title = T("Admin.Orders.Products.AddNew.Title2", Model.Name, Model.OrderId);

    var warnings = ViewBag.Warnings as List<string>;
}

<script src="~/admin/js/admin.taxconverter.js" sm-target-zone="scripts" sm-key="tax-converter"></script>

@*We add enctype = "multipart/form-data" because "File upload" attribute control type requries it.*@
<form id="AddProductToOrderForm" method="post" asp-action="AddProductToOrder" asp-route-orderId="@Model.OrderId" asp-route-productId="@Model.ProductId" enctype="multipart/form-data">
    @Html.HiddenFor(x => x.OrderId)
    @Html.HiddenFor(x => x.ProductId)

    <div class="section-header">
        <div class="title">
            <a sm-backto asp-action="Edit" asp-route-id="@Model.OrderId" title="@T("Admin.Orders.Products.AddNew.BackToOrder")"></a>
            <i class="far fa-chart-bar"></i>
            <span>@ViewBag.Title</span>
        </div>
        <div class="options">
            <zone name="admin_button_toolbar_before" />
            <zone name="admin_button_toolbar_after" />
        </div>
    </div>

    <div sm-if="!warnings.IsNullOrEmpty()">
        <div class="alert alert-danger">
            @foreach (var warning in warnings)
            {
                <div>@Html.Raw(warning)</div>
            }
        </div>
    </div>

    @if (Model.ProductType == ProductType.GroupedProduct)
    {
        <div class="alert alert-warning">A group product cannot be added to an order. Please select a product associated to the grouped product.</div>
        return;
    }
    else if (Model.ProductType == ProductType.BundledProduct)
    {
        <div class="alert alert-warning">Adding a product bundle to an existing order is currently not supported.</div>
        return;
    }

    <div id="AddProductToOrderPrices">
        <partial name="_AddProductToOrder.Prices" />
    </div>

    @if (Model.ProductVariantAttributes.Count > 0)
    {
        <partial name="_AddProductToOrder.Attributes" />
    }

    @if (Model.GiftCard.IsGiftCard)
    {
        var giftCardViewData = new ViewDataDictionary(ViewData);
        giftCardViewData.TemplateInfo.HtmlFieldPrefix = Model.GiftCardFieldPrefix;

        <partial name="_AddProductToOrder.GiftCardInfo" model="Model.GiftCard" view-data="giftCardViewData" />
    }

    <div class="adminContent">
        <div class="adminRow">
            <div class="adminTitle">
                <smart-label asp-for="AdjustInventory" />
            </div>
            <div class="adminData">
                <input asp-for="AdjustInventory" />
            </div>
        </div>
        <div sm-if="Model.ShowUpdateTotals" class="adminRow">
            <div class="adminTitle">
                <smart-label asp-for="UpdateTotals" />
            </div>
            <div class="adminData">
                <input asp-for="UpdateTotals" />
            </div>
        </div>
        <div class="adminRow">
            <div class="adminTitle">
            </div>
            <div class="adminData">
                <button type="submit" class="btn btn-secondary confirm2" data-confirm-message="@T("Admin.Common.AskToProceed")">
                    <i class="fa fa-plus"></i>
                    <span>@T("Admin.Orders.Products.AddNew")</span>
                </button>
            </div>
        </div>
    </div>
</form>

<script sm-target-zone="scripts" data-origin="add-product-to-order">
    $(function () {
        applyCommonPlugins($('#AddProductAttributeContainer'));
        
        $('#AddProductToOrderForm').on('change', '#Quantity, .attribute-list, .attribute-list-item', () => {
            $({}).ajax({
                type: 'POST',
                url: '@Url.Action("UpdateProductPrices")',
                data: $('#AddProductToOrderForm').serialize(),
                success: (response) => {
                    if (response.success) {
                        const $elPrices = $('#AddProductToOrderPrices');
                        $elPrices.html(response.prices);
                        applyCommonPlugins($elPrices);
                    }
                }
            });
        });

        window.taxConverterRes = {
		    @foreach (var key in new[]
            {
                "Admin.Common.TaxConversion.Enable",
                "Admin.Common.TaxConversion.Disable"
            })
            {
			    <text>"@(Html.Raw(key))": @(T(key).JsValue),</text>
		    }
        };

        Smartstore.Admin.taxConverter.initialize({
            pricesIncludeTax: @(TaxSettings.PricesIncludeTax.ToString().ToLowerInvariant())
        });
    });
</script>
