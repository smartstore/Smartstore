@using Smartstore.Web.Models.Catalog

@model BrandModel

@{
    Assets.AppendTitleParts(Model.MetaTitle.HasValue() ? Model.MetaTitle : Model.Name);
    Assets.AppendMetaDescriptionParts(Model.MetaDescription);
    Assets.AppendMetaKeywordsParts(Model.MetaKeywords);

    if (Model.CanonicalUrl.HasValue())
    {
        Assets.AppendCanonicalUrlParts(Model.CanonicalUrl);
    }

    ViewBag.HideLeftCol = true; // ...on mobile
}

<partial name="MetaProperties" model="Model.MetaProperties" />

<widget target-zone="left">
    <partial name="Search.Filters" model="Model.Products" />
</widget>

<div class="page manufacturer-page" itemscope itemtype="https://schema.org/CollectionPage">
    <div class="page-title">
        <h1 sm-language-attributes-for="Model.Name" class="h3" itemprop="name">
            @Html.Raw(Model.Name)
        </h1>
        @if (Model.SearchResult.TotalHitsCount > 0)
        {
            <partial name="SearchResultHitsCount" model="Model.SearchResult" />
        }
    </div>

    <div class="page-body">
        <zone name="manufacturerdetails_top" />

        @* Description *@
        @if (Model.Description.HasValue())
        {
            <div sm-language-attributes-for="Model.Description" 
                 id="manufacturer-description-top"
                 class="manufacturer-description lead html-editor-content"
                 itemprop="description">
                <collapsed-content>
                    @Html.Raw(Model.Description)
                </collapsed-content>
            </div>
        }

        @* Featured products *@
        @if (Model.FeaturedProducts != null && Model.FeaturedProducts.Items.Count > 0)
        {
            <zone name="manufacturerdetails_before_featured_products" />

            <div role="region" aria-labelledby="featured-products-title" class="product-grid featured-product-grid block">
                <div class="heading heading-center">
                    <h3 id="featured-products-title" class="heading-title fs-h1">@T("Products.FeaturedProducts")</h3>
                </div>
                <div id="featured-product-list" class="block-body pt-3 artlist-no-separators">
                    <partial name="Product.List" model="Model.FeaturedProducts" />
                </div>
            </div>
        }

        @* Product list *@
        <zone name="categorydetails_before_product_list" />

        <div id="main-product-list" class="product-list-container">
            @if (Model.Products != null)
            {
                <partial name="Product.List" model="Model.Products" />
            }
        </div>

        @if (Model.BottomDescription.Value.HasValue())
        {
            <div sm-language-attributes-for="Model.BottomDescription" class="manufacturer-description lead html-editor-content">
                <collapsed-content>
                    @Html.Raw(Model.BottomDescription)
                </collapsed-content>
            </div>
        }

        @* TODO: (mc) find more intelligent way of rendering RecentlyViewedProducts globally *@
        @await Component.InvokeAsync("RecentlyViewedProducts")
        <zone name="manufacturerdetails_bottom" />
    </div>
</div>

@{
    // TODO: (jsonld) This is nearly identical to the code in CategoryTemplate.ProductsInGridOrLines.cshtml. We should find a way to reuse it.

    // Build JSON-LD for the category CollectionPage including featured and regular product lists.
    var url = Model.CanonicalUrl.NullEmpty();

    Assets.JsonLd.CollectionPage
        .Prop("@id", url + "#webpage")
        .Prop("name", Model.Name)
        .Obj("about", JsonLdFragment.Create("Brand")
            .Prop("@id", url + "#brand")
            .Prop("name", Model.Name)
            .Prop("url", url));

    if (Model.Products != null && Model.Products.Items.Count > 0)
    {
        Assets.JsonLd.CollectionPage.Prop("mainEntity", new Dictionary<string, string> { ["@id"] = url + "#main-product-list" });

        JsonLdHelper.BuildProductItemList(Assets.JsonLd, Url, Model.Products.Items, @Model.Name, url + "#main-product-list", url);
    }

    if (Model.Description.Value.HasValue())
    {
        Assets.JsonLd.CollectionPage.Prop("description", new Dictionary<string, string> { ["@id"] = url + "#manufacturer-description-top" });
    }

    if (Model.FeaturedProducts != null && Model.FeaturedProducts.Items.Count > 0)
    {
        Assets.JsonLd.CollectionPage.Prop("hasPart", new Dictionary<string, string> { ["@id"] = url + "#featured-product-list" });

        // TODO: (jsonld) This also needs to build json ld but currently we have no way of distinguishing featured vs regular products in the list.
        // Shortcoming of JsonLdBuilder
        // JsonLdHelper.BuildProductItemList(Assets.JsonLd, Model.Products.Items, @Model.Name, url);
    }
}